# -----------------------------------------------------------------------------
# Adams Sports News — environment variables.
#
# Copy this file to `.env` (git-ignored) and fill in your own values.
# Never commit real credentials. Rotate keys in each provider's dashboard
# if they are ever exposed.
# -----------------------------------------------------------------------------

# ---- Server: third-party news APIs ----
# https://newsapi.org/
NEWS_API_KEY=
# https://gnews.io/
GNEWS_API_KEY=
# https://www.api-football.com/
API_FOOTBALL_KEY=

# ---- Client: Supabase (prefixed with VITE_ so Vite injects them) ----
# Project URL, e.g. https://<ref>.supabase.co
VITE_SUPABASE_URL=
# Anon / publishable key (safe to ship to the browser). Do NOT put the
# service-role key here.
VITE_SUPABASE_PUBLISHABLE_KEY=

# ---- Server: Supabase (for auth verification + DB via service role) ----
# Same URL as VITE_SUPABASE_URL.
SUPABASE_URL=
# Service role key — BYPASSES Row-Level Security. Server-only, never
# expose to the browser. Get from: Supabase Dashboard → Project Settings
# → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=
# Anon key for auth signIn fallbacks. Usually same as VITE_SUPABASE_PUBLISHABLE_KEY.
SUPABASE_ANON_KEY=

# When SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are both set, the server
# uses Supabase Postgres as the backing store for all per-user data.
# Otherwise it falls back to JSON files in DATA_DIR.
#
# Schema is defined in server/db/schema.sql — run it once via the Supabase
# dashboard SQL editor (or the Management API) to create the tables and
# RLS policies.

# ---- Push notifications (web-push / VAPID) ----
# Generate once with: npx web-push generate-vapid-keys
# VAPID_SUBJECT should be a mailto: or https: URL you control.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ---- Database ----
# If set, the server will use Drizzle/Postgres (see shared/dbSchema.ts) and
# you can run `npm run db:push`. If not set, data is persisted to JSON files
# under .data/ — fine for dev and small deployments.
DATABASE_URL=

# ---- Runtime ----
# Default 5000. The server is the only port exposed.
PORT=5000

# Override the data dir for JSON persistence (default: ./.data)
# DATA_DIR=./.data

# Disable background workers (live score broadcast, news alerts, bet
# settlement). Useful for tests.
# DISABLE_WORKERS=true
