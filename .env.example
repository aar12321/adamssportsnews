# -----------------------------------------------------------------------------
# Adams Sports News — environment variables.
#
# Copy this file to `.env` (git-ignored) and fill in your own values.
# Never commit real credentials. Rotate keys in each provider's dashboard
# if they are ever exposed.
# -----------------------------------------------------------------------------

# ---- Server: auth (REQUIRED in production) ----
# When these are unset the server degrades to INSECURE dev mode: the
# requireSelf middleware falls back to trusting the :userId path param,
# which means any signed-in caller could mutate anyone else's data.
# Ship both in every non-dev environment.
# Project URL, e.g. https://<ref>.supabase.co
SUPABASE_URL=
# Anon key (same one the client uses). NOT the service-role key.
SUPABASE_ANON_KEY=

# ---- Server: third-party news APIs (optional, enable richer feeds) ----
# https://newsapi.org/
NEWS_API_KEY=
# https://gnews.io/
GNEWS_API_KEY=
# https://www.api-football.com/
API_FOOTBALL_KEY=

# ---- Server: sportsbook lines (optional, enables real moneyline data) ----
# https://the-odds-api.com/
ODDS_API_KEY=

# ---- Server: Claude / Anthropic (optional, powers AI features) ----
# Used by the "Ask the AI for a take" button in the Betting app. Without
# it, AI-powered endpoints are disabled and the UI hides its affordances.
# Get a key at https://console.anthropic.com/settings/keys and store it
# ONLY in the server environment — never commit it, never expose it to
# the browser.
ANTHROPIC_API_KEY=

# ---- Client: Supabase (prefixed with VITE_ so Vite injects them) ----
# Usually the same URL as SUPABASE_URL above.
VITE_SUPABASE_URL=
# Anon / publishable key (safe to ship to the browser). Do NOT put the
# service-role key here.
VITE_SUPABASE_PUBLISHABLE_KEY=

# ---- Runtime ----
# "development" | "production". Defaults to development when unset.
NODE_ENV=development
# Default 5000. The server is the only port exposed.
PORT=5000
# Directory for runtime JSON snapshots (betting + user preferences).
# Default ./data. Make sure the process can write here, otherwise the
# server falls back to in-memory and loses state on every restart.
DATA_DIR=./data

# ---- Server: Postgres (optional, recommended for production) ----
# When set, betting + user preferences hydrate from Postgres on boot
# and write back on every mutation (debounced). When unset, the server
# falls back to JSON snapshots under DATA_DIR. We use the Neon HTTP
# driver so it works from both long-lived Node and serverless. Format:
# postgres://USER:PASSWORD@HOST/DATABASE?sslmode=require
# Generate one at https://console.neon.tech/ — point this at the
# branch you want to write to. After setting it, run `npm run db:push`
# to apply the schema. Local dev / tests run fine without it.
DATABASE_URL=
